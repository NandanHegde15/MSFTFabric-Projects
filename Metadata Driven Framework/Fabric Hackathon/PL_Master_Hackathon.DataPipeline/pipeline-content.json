                  "connection": "bb02827c-eac2-417e-b83f-62a75c5259b3"
                },
                "annotations": []
              }
            },
            "annotations": []
          },
          "firstRowOnly": false
        },
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
