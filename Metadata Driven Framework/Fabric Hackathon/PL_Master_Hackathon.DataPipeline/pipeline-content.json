        "type": "Lookup",
        "typeProperties": {
          "source": {
            "type": "FabricSqlDatabaseSource",
            "sqlReaderQuery": "SELECT\n    ac.*,                     \n    ap.AbsoluteUrl,\n    ap.MaxRequestNumber\nFROM Config.ApiConfig ac\nLEFT JOIN (\n    SELECT\n        ApiConfigId,\n        MAX(CASE WHEN PaginationType = 'AbsoluteUrl'\n                 THEN PaginationValue END) AS AbsoluteUrl,\n        MAX(CASE WHEN PaginationType = 'MaxRequestNumber'\n                 THEN PaginationValue END) AS MaxRequestNumber\n    FROM Config.ApiPagination\n    WHERE PaginationType IN ('AbsoluteUrl', 'MaxRequestNumber')\n    GROUP BY ApiConfigId\n) ap\n    ON ac.ApiConfigId = ap.ApiConfigId;",
            "partitionOption": "None",
            "queryTimeout": "02:00:00"
          },
          "datasetSettings": {
            "type": "FabricSqlDatabaseTable",
            "schema": [],
            "connectionSettings": {
              "name": "SqlHackathon",
              "properties": {
                "type": "FabricSqlDatabase",
